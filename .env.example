# Agent Team Exercise Environment Configuration
# Copy this file to .env and fill in your values.

# ──────────────────────────────────────────────────────────────
# 模型配置（必填）
# 格式: MODEL=provider:model
# 当前支持的 provider: tongyi（通义千问）, glm（智谱GLM）, kimi（月之暗面）, longcat（美团LongCat）
# ──────────────────────────────────────────────────────────────

# 美团 LongCat 示例
MODEL=longcat:LongCat-2.0
LONGCAT_API_KEY=请在此填写你的美团 LongCat API Key
# LONGCAT_BASE_URL=https://api.longcat.chat/openai

# Kimi（月之暗面）示例（二选一，取消注释即可切换）
# MODEL=kimi:kimi-for-coding
# KIMI_API_KEY=请在此填写你的Kimi API Key
# KIMI_BASE_URL=https://api.kimi.com/coding/v1

# 通义千问（阿里云百炼）示例（二选一，取消注释即可切换）
# MODEL=tongyi:qwen-turbo
# TONGYI_API_KEY=请在此填写你的通义千问API Key
# TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 智谱 GLM 示例（二选一，取消注释即可切换）
# MODEL=glm:glm-4-flash
# GLM_API_KEY=请在此填写你的智谱API Key
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 限制助手输出长度，0 表示禁用（memory 分支的流式功能使用）
# MODEL_MAX_TOKENS=800
# MODEL_STREAM_MAX_CHARS=6000

# ──────────────────────────────────────────────────────────────
# 高德/百度地图工具 Key（可选，tools 模块使用）
# ──────────────────────────────────────────────────────────────
# AMAP_API_KEY=请在此填写高德地图Key
# BAIDU_API_KEY=请在此填写百度地图Key

# ──────────────────────────────────────────────────────────────
# Agent 行为配置（可选）
# ──────────────────────────────────────────────────────────────
# AGENT_NAME=TeachAgent
# ENABLE_CONTEXT=true
# ENABLE_MEMORY=true
# LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────
# 向量记忆配置（可选，memory 模块使用）
# 未安装 Qdrant / Ollama 时设 ENABLE_VECTOR_MEMORY=false 降级
# ──────────────────────────────────────────────────────────────
# ENABLE_VECTOR_MEMORY=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_EMBED_MODEL=bge-m3
# OLLAMA_TIMEOUT=5
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=agent_conversations
# QDRANT_VECTOR_SIZE=1024
# QDRANT_DISTANCE=Cosine
# QDRANT_TIMEOUT=3
# VECTOR_MEMORY_TOP_K=5
# VECTOR_MEMORY_SCORE_THRESHOLD=0.65
# VECTOR_MEMORY_MAX_CHARS=800

# ──────────────────────────────────────────────────────────────
# 流式输出配置（可选）
# ──────────────────────────────────────────────────────────────
# ENABLE_STREAMING=true

# ──────────────────────────────────────────────────────────────
# Girlfriend 人格层配置（可选，memory 分支引入）
# 默认关闭，按需开启
# ──────────────────────────────────────────────────────────────
# ENABLE_GIRLFRIEND_MODE=false
# GIRLFRIEND_DB_PATH=girlfriend/girlfriend.db
# GIRLFRIEND_MOOD_MIN=-100
# GIRLFRIEND_MOOD_MAX=100
# GIRLFRIEND_NEGATIVE_INTENSITY=medium
# GIRLFRIEND_ENABLE_AI_JUDGE=true
# GIRLFRIEND_NEGLECT_MIN_SECONDS=900
# GIRLFRIEND_PROACTIVE_MIN_SECONDS=180
# GIRLFRIEND_PROACTIVE_MAX_SECONDS=7200
# GIRLFRIEND_CONTINUOUS_CHAT=true
# GIRLFRIEND_CONTINUOUS_MIN_SECONDS=30
# GIRLFRIEND_CONTINUOUS_MAX_SECONDS=120
# GIRLFRIEND_PROACTIVE_USE_AI=true
# GIRLFRIEND_PROACTIVE_BURST_CHANCE=0.35
# GIRLFRIEND_PROACTIVE_BURST_MAX=3
# GIRLFRIEND_CRISIS_PROACTIVE_MIN_SECONDS=3
# GIRLFRIEND_CRISIS_PROACTIVE_MAX_SECONDS=20
# ENABLE_HUMAN_PAUSES=true
# HUMAN_PAUSE_MIN_SECONDS=0.03
# HUMAN_PAUSE_MAX_SECONDS=0.16

# ──────────────────────────────────────────────────────────────
# Subagent / Supervisor 编排配置（可选）
# ──────────────────────────────────────────────────────────────
# Enable event-driven agent orchestration (true/false)
# When false, the original synchronous task tool path is used.
ENABLE_EVENT_DRIVEN=false

# Maximum retries for failed sub-agent tasks in event-driven mode
MAX_RETRIES=2

# Workflow completion timeout in seconds for event-driven mode
# If a workflow does not complete within this time, the turn returns a timeout message.
WORKFLOW_TIMEOUT_SECONDS=300
