# Agent Team Exercise Environment Configuration
# Copy this file to .env and fill in your values.

# Example: OpenAI-compatible base URL (e.g. Aliyun DashScope)
# MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Example: API key for the model provider
# MODEL_API_KEY=your_api_key_here

# Example: Model name used by the Model module
# MODEL_NAME=qwen-turbo

# Example: Agent name shown in the REPL prompt
# AGENT_NAME=TeachAgent

# Example: Enable context updates (true/false)
# ENABLE_CONTEXT=true

# Example: Enable memory storage (true/false)
# ENABLE_MEMORY=true

# Example: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Example: Enable event-driven agent orchestration (true/false)
# When false, the original synchronous task tool path is used.
ENABLE_EVENT_DRIVEN=false

# Example: Maximum retries for failed sub-agent tasks in event-driven mode
MAX_RETRIES=2

# Example: Workflow completion timeout in seconds for event-driven mode
# If a workflow does not complete within this time, the turn returns a timeout message.
WORKFLOW_TIMEOUT_SECONDS=300

# Example: State store backend (memory or postgres)
STATE_STORE_BACKEND=memory

# Example: PostgreSQL connection URL when STATE_STORE_BACKEND=postgres
DATABASE_URL=postgresql://user:pass@localhost:5432/agent_team

# Example: Event bus backend (memory or kafka)
EVENT_BUS_BACKEND=memory

# Example: Kafka configuration when EVENT_BUS_BACKEND=kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=agent-team
KAFKA_CONSUMER_GROUP=agent-team
KAFKA_TOPIC_PREFIX=

# Example: Redis configuration when REDIS_ENABLED=true
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
