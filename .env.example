# Agent Team Exercise Environment Configuration
# Copy this file to .env and fill in your values.

# ──────────────────────────────────────────────────────────────
# 模型配置（必填）
# 格式: MODEL=provider:model
# 当前支持的 provider: deepseek, tongyi（通义千问）, glm（智谱GLM）, kimi（月之暗面）
# ──────────────────────────────────────────────────────────────

# DeepSeek 示例（默认）
MODEL=deepseek:deepseek-v4-pro
DEEPSEEK_API_KEY=请在此填写你的DeepSeek API Key
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# 记忆系统默认使用 DeepSeek 抽取 + Ollama bge-m3 embedding
MEMORY_EXTRACTOR_PROVIDER=deepseek
MEMORY_DEEPSEEK_MODEL=deepseek-v4-pro
MEMORY_EMBEDDING_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=bge-m3

# Kimi（月之暗面）示例（二选一，取消注释即可切换）
# MODEL=kimi:kimi-k2.7-code-highspeed
# KIMI_API_KEY=请在此填写你的Kimi API Key
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# 通义千问（阿里云百炼）示例（二选一，取消注释即可切换）
# MODEL=tongyi:qwen-turbo
# TONGYI_API_KEY=请在此填写你的通义千问API Key
# TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 智谱 GLM 示例（二选一，取消注释即可切换）
# MODEL=glm:glm-4-flash
# GLM_API_KEY=请在此填写你的智谱API Key
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# ──────────────────────────────────────────────────────────────
# 高德/百度地图工具 Key（可选，tools 模块使用）
# ──────────────────────────────────────────────────────────────
# AMAP_API_KEY=请在此填写高德地图Key
# BAIDU_API_KEY=请在此填写百度地图Key

# ──────────────────────────────────────────────────────────────
# Agent 行为配置（可选）
# ──────────────────────────────────────────────────────────────
# AGENT_NAME=TeachAgent
# ENABLE_CONTEXT=true
# ENABLE_MEMORY=true
# LOG_LEVEL=INFO
